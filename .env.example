# ============================================
# HillSignal Environment Variables
# ============================================
# Copy this file to .env.local for local development
# Add these variables to Railway for production

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Find these in: Supabase Dashboard > Project Settings > API

# Project URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://oiwuwllrtjiqrpmadqiu.supabase.co

# Anon/Public Key (safe to expose to client - used for client-side auth)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9pd3V3bGxydGppcXJwbWFkcWl1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMzMjQ5NTYsImV4cCI6MjA4ODkwMDk1Nn0.Sfp-V2Ccxhq3R0aZumv8wm2OGlbGjQhLfBZRCisyomQ

# Service Role Key (NEVER expose to client - server-side only)
# Find in: Supabase Dashboard > Project Settings > API > service_role key
# This key bypasses RLS - only use on server
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# STRIPE CONFIGURATION
# ============================================
# Find these in: Stripe Dashboard > Developers > API keys

# Publishable Key (safe to expose to client)
# Use test key (pk_test_xxx) for development, live key (pk_live_xxx) for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret Key (NEVER expose to client - server-side only)
# Use test key (sk_test_xxx) for development, live key (sk_live_xxx) for production
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook Secret (NEVER expose to client)
# Find in: Stripe Dashboard > Developers > Webhooks > Select endpoint > Signing secret
# You'll get this after creating the webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Your domain (used for Stripe redirects and email links)
# Development: http://localhost:3000
# Production: https://hillsignal.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
